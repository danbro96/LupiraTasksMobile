{
  "name": "lupiratasksmobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch:openapi": "node scripts/fetch-openapi.mjs",
    "gen:api": "orval --config ./orval.config.ts",
    "build:preview": "eas build --profile preview --platform android",
    "build:android": "eas build --profile production --platform android"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@sentry/react-native": "^8.13.0",
    "@tanstack/react-query": "^5.101.0",
    "babel-preset-expo": "~56.0.0",
    "expo": "56.0.8",
    "expo-auth-session": "~56.0.13",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "56.0.18",
    "expo-secure-store": "~56.0.4",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.18",
    "expo-web-browser": "~56.0.5",
    "fractional-indexing": "^3.2.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "uuid": "^14.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "19.2.16",
    "orval": "^8.15.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "private": true
}
